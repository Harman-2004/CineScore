# FastAPI Security Configuration
# CRITICAL: Change this value to a secure, random string in production
SECRET_KEY=

# Database Configuration
# Set your local SQLite, local PostgreSQL, or Neon PostgreSQL connection URL
# e.g., postgresql://username:password@ep-cool-name.us-east-2.aws.neon.tech/movie_db?sslmode=require
DATABASE_URL=

# Third-Party API Integrations
# Optional: Leave empty to run using fallback simulated mock data
TMDB_API_KEY=
OMDB_API_KEY=
YOUTUBE_API_KEY=

# App General Settings
PROJECT_NAME="Movie AI Rating Platform"
ENVIRONMENT=development
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
