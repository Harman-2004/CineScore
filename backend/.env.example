# FastAPI Security Configuration
SECRET_KEY=supersecretjwtkeythatshouldbechangedinproduction12345
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database Configuration
# Use local localhost for running without docker, or 'db' host for docker-compose
DATABASE_URL=postgresql://postgres:postgres@db:5432/movie_db

# TMDb Integration
# Get your API key/token from https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# OMDb Integration (for official IMDb & Metacritic ratings)
# Get your API key from http://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=your_omdb_api_key_here

# App general settings
PROJECT_NAME="Movie AI Rating Platform"
ENVIRONMENT=development
